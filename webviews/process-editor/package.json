    "@axonivy/process-editor-inscription": "~14.0.0-next.2179.05c90817",
    "@axonivy/process-editor-inscription-view": "~14.0.0-next.2179.05c90817",
    "@axonivy/process-editor-protocol": "~14.0.0-next.2179.05c90817",
