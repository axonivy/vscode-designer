{
  "name": "@axonivy/vscode-webview-process-editor",
  "private": true,
  "version": "14.0.0",
  "description": "VSCode extension webview for the Axon Ivy (GLSP-based) process editor",
  "license": "(EPL-2.0 OR GPL-2.0 WITH Classpath-exception-2.0)",
  "keywords": [
    "vscode",
    "graph",
    "diagram",
    "layout",
    "glsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/axonivy/process-editor"
  },
  "dependencies": {
    "@axonivy/process-editor": "next-14.0.0",
    "@axonivy/process-editor-inscription": "next-14.0.0",
    "@axonivy/process-editor-inscription-view": "next-14.0.0",
    "@axonivy/process-editor-protocol": "next-14.0.0",
    "@axonivy/vscode-webview-common": "workspace:~",
    "@eclipse-glsp/client": "2.7.0",
    "@eclipse-glsp/vscode-integration": "2.7.0",
    "@eclipse-glsp/vscode-integration-webview": "2.7.0",
    "i18next": "26.3.6",
    "inversify": "6.2.2",
    "vscode-messenger-common": "0.4.5",
    "vscode-messenger-webview": "0.4.5"
  },
  "peerDependencies": {
    "@hediet/json-rpc": "^0.5",
    "@monaco-editor/react": "^4.7"
  },
  "devDependencies": {
    "@axonivy/monaco-vite-plugin": "next-14.0.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vscode/codicons": "0.0.45",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "type": "module",
  "scripts": {
    "build": "vite build --mode development --emptyOutDir",
    "build:production": "vite build --emptyOutDir",
