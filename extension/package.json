{
  "name": "vscode-designer-14",
  "private": true,
  "preview": true,
  "version": "14.0.0",
  "description": "This extension gives you all the tools you need to design, automate and optimize workflows from simple tasks to complex enterprise processes.",
  "publisher": "axonivy",
  "author": "Axon Ivy AG",
  "type": "module",
  "homepage": "https://developer.axonivy.com/",
  "repository": {
    "url": "https://github.com/axonivy/vscode-designer"
  },
  "icon": "assets/ivy-logo.png",
  "displayName": "Axon Ivy PRO Designer 14",
  "engines": {
    "vscode": "^1.98.0"
  },
  "scripts": {
    "build": "node esbuild.mts",
    "build:production": "node esbuild.mts --production",
    "clean": "rimraf lib dist *.tsbuildinfo",
    "generate:market": "node ./schemaCodegen.cjs",
    "package": "bash -c 'vsce package --no-update-package-json --no-git-tag-version --no-dependencies ${npm_package_version:0:4}.$(date \"+%Y%m%d%H\")'",
    "publish:next": "bash -c 'vsce publish --no-update-package-json --no-git-tag-version --no-dependencies ${npm_package_version:0:4}.$(date \"+%Y%m%d%H\")'",
    "test": "vitest",
    "test:ci": "vitest run",
    "type": "tsc --noEmit",
    "watch": "node esbuild.mts --watch"
  },
  "main": "./dist/extension.js",
  "dependencies": {
    "@axonivy/cms-editor-protocol": "~14.0.0-next.759.11c0e51",
    "@axonivy/database-editor-protocol": "~14.0.0-next.366.b90a8f5",
    "@axonivy/dataclass-editor-protocol": "~14.0.0-next.913.7c91f04",
    "@axonivy/case-map-editor-protocol": "~14.0.0-next.299.be23cdf",
    "@axonivy/form-editor-protocol": "~14.0.0-next.1228.045750f",
    "@axonivy/jsonrpc": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/log-view-core": "~14.0.0-next.435.99c71d0",
    "@axonivy/log-view-protocol": "~14.0.0-next.435.99c71d0",
    "@axonivy/process-editor-inscription-protocol": "~14.0.0-next.2193.8e54b8a7",
    "@axonivy/process-editor-protocol": "~14.0.0-next.2193.8e54b8a7",
    "@axonivy/role-editor-protocol": "~14.0.0-next.195.4ae7507",
    "@axonivy/user-editor-protocol": "~14.0.0-next.148.7a29892",
    "@axonivy/persistence-editor-protocol": "~14.0.0-next.123.da482c3",
    "@axonivy/restclient-editor-protocol": "~14.0.0-next.147.961693",
    "@axonivy/webservice-editor-protocol": "~14.0.0-next.106.3bf39bc",
    "@axonivy/variable-editor-protocol": "~14.0.0-next.1057.acfe4ff",
    "@eclipse-glsp/protocol": "2.6.0",
    "@eclipse-glsp/vscode-integration": "2.6.0",
    "axios": "1.15.2",
    "dom-serializer": "3.0.0",
    "domhandler": "6.0.1",
    "fast-xml-parser": "5.7.2",
    "htmlparser2": "12.0.0",
    "vscode-languageclient": "9.0.1",
    "vscode-languageserver-textdocument": "1.0.12",
    "vscode-messenger": "0.4.5",
    "vscode-messenger-common": "0.4.5",
    "vscode-ws-jsonrpc": "3.5.0",
    "vscode-languageserver-protocol": "3.17.5",
    "rss-parser": "3.13.0"
  },
  "devDependencies": {
    "@types/vscode": "1.98.0",
    "@types/vscode-webview": "1.57.5",
    "@vscode/vsce": "3.9.1",
    "esbuild": "0.28.0",
    "vitest": "4.1.5",
    "json-schema-to-typescript": "^15.0.4"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "redhat.java",
    "vscjava.vscode-java-debug",
    "vscjava.vscode-java-test",
    "vscjava.vscode-maven",
    "vscjava.vscode-java-dependency"
  ],
  "contributes": {
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "{git,gitlens}:/**/{*.p.json,*.d.json,*.f.json,*.yaml}": "default"
      },
      "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://json-schema.axonivy.com/": true
      },
      "html.suggest.html5": false,
      "java.configuration.updateBuildConfiguration": "automatic"
    },
    "customEditors": [
      {
        "viewType": "ivy.variableEditor",
        "displayName": "Axon Ivy Variables Editor",
        "selector": [
          {
            "filenamePattern": "variables.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.roleEditor",
        "displayName": "Axon Ivy Role Editor",
        "selector": [
          {
            "filenamePattern": "roles.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.persistenceEditor",
        "displayName": "Axon Ivy Persistence Editor",
        "selector": [
          {
            "filenamePattern": "persistence.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.userEditor",
        "displayName": "Axon Ivy User Editor",
        "selector": [
          {
            "filenamePattern": "users.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.restClientEditor",
        "displayName": "Axon Ivy Rest Client Editor",
        "selector": [
          {
            "filenamePattern": "rest-clients.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.webServiceClientEditor",
        "displayName": "Axon Ivy Web Service Client Editor",
        "selector": [
          {
            "filenamePattern": "webservice-clients.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.databaseEditor",
        "displayName": "Axon Ivy Database Editor",
        "selector": [
          {
            "filenamePattern": "databases.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.cmsEditor",
        "displayName": "Axon Ivy CMS Editor",
        "selector": [
          {
            "filenamePattern": "cms_*.yaml"
          }
        ]
      },
      {
        "viewType": "ivy.glspDiagram",
        "displayName": "Axon Ivy Process Editor",
        "selector": [
          {
            "filenamePattern": "*.p.json"
          }
        ]
      },
      {
        "viewType": "ivy.casemapEditor",
        "displayName": "Axon Ivy Case Map Editor",
        "selector": [
          {
            "filenamePattern": "*.m.json"
          }
        ]
      },
      {
        "viewType": "ivy.formEditor",
        "displayName": "Axon Ivy Form Editor",
        "selector": [
          {
            "filenamePattern": "*.f.json"
          }
        ]
      },
      {
        "viewType": "ivy.dataClassEditor",
        "displayName": "Axon Ivy Data Class Editor",
        "selector": [
          {
            "filenamePattern": "*.d.json"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "ivyEditor.openVariableEditor",
        "title": "Open Variable Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openCmsEditor",
        "title": "Open CMS Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openDatabaseEditor",
        "title": "Open Database Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openRoleEditor",
        "title": "Open Role Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openUserEditor",
        "title": "Open User Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openRestClientEditor",
        "title": "Open Rest Client Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openWebServiceClientEditor",
        "title": "Open Web Service Client Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyEditor.openCustomFieldEditor",
        "title": "Open Custom Field Editor",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyBrowserView.openDevWfUi",
        "title": "Open Developer Workflow UI",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyBrowserView.openEngineCockpit",
        "title": "Open Engine Cockpit",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyBrowserView.openNEO",
        "title": "Open NEO",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyBrowserView.openPreview",
        "title": "Open Dialog Preview",
        "category": "Axon Ivy",
        "icon": "$(play)",
        "enablement": "ivy:hasIvyProjects && ivy:dialogPreviewSupported"
      },
      {
        "command": "ivyBrowserView.open",
        "title": "Open Ivy Browser",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyPanelView.openRuntimeLog",
        "title": "Open Axon Ivy Runtime Log",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyPanelView.openWelcomePage",
        "title": "Open Welcome Page",
        "category": "Axon Ivy"
      },
      {
        "command": "workflow.fit",
        "title": "Fit to Screen",
        "category": "Axon Ivy",
        "enablement": "activeCustomEditorId == 'ivy.glspDiagram'"
      },
      {
        "command": "workflow.center",
        "title": "Center selection",
        "category": "Axon Ivy",
        "enablement": "activeCustomEditorId == 'ivy.glspDiagram'"
      },
      {
        "command": "workflow.layout",
        "title": "Layout diagram",
        "category": "Axon Ivy",
        "enablement": "activeCustomEditorId == 'ivy.glspDiagram'"
      },
      {
        "command": "workflow.exportAsSVG",
