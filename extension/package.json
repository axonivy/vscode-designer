      },
      {
        "command": "ivyProjects.installMarketProduct",
        "title": "Install Market Product",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addNewProject",
        "title": "New Project",
        "category": "Axon Ivy",
        "icon": "$(add)"
      },
      {
        "command": "ivyProjects.addNewHtmlDialog",
        "title": "New Html Dialog (JSF)",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addNewFormDialog",
        "title": "New Dialog Form",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addNewOfflineDialog",
        "title": "New Offline Dialog (JSF)",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addNewDataClass",
        "title": "New Data Class",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addNewEntityClass",
        "title": "New Entity Class",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addNewCaseMap",
        "title": "New Case Map",
        "category": "Axon Ivy"
      },
      {
        "command": "ivyProjects.addDependency",
        "title": "Add Ivy Project Dependency",
        "category": "Axon Ivy",
        "icon": "$(add)",
        "enablement": "ivy:hasIvyProjects"
      },
      {
        "command": "ivy.addDevContainer",
        "title": "Add Dev Container",
        "category": "Axon Ivy"
      },
      {
        "command": "engine.activateAnimation",
        "title": "Activate Process Animation",
        "category": "Axon Ivy"
      },
      {
        "command": "engine.deactivateAnimation",
        "title": "Deactivate Process Animation",
        "category": "Axon Ivy"
      }
    ],
    "configuration": [
      {
        "title": "Axon Ivy",
        "properties": {
          "axonivy.engine.runByExtension": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "Configure whether a local Axon Ivy Engine will be run by this extension. If set true, you can specify `#axonivy.engine.releaseTrain#`. If set false, you have to define `#axonivy.engine.url#`.",
            "order": 1000
          },
          "axonivy.engine.releaseTrain": {
            "type": "string",
            "default": "",
            "markdownDescription": "Release train of Axon Ivy Engine to be used as Developer Engine. Expected to be a release tag like '14.0' or an absoulute path to an existing Axon Ivy Engine.",
            "order": 1100
          },
          "axonivy.engine.url": {
            "type": "string",
            "default": "http://localhost:8080/",
            "markdownDescription": "Url of the Axon Ivy Engine that will be used as backend. Only relevant if `#axonivy.engine.runByExtension#` is set to false.",
            "order": 1200
          },
          "axonivy.engine.vmArgs": {
            "type": "string",
            "default": "",
            "markdownDescription": "Specifies extra VM arguments used to launch the Axon Ivy Engine. Eg. use `-agentlib:jdwp=transport=dt_socket,server=y,address=*:8000,suspend=n` to enable remote debugging.",
            "order": 1300
          },
          "axonivy.project.excludePattern": {
            "type": "string",
            "default": "**/target/**",
            "markdownDescription": "A Glob Pattern that is used to exclude Axon Ivy projects during detection. [Learn more about Glob Pattern](https://code.visualstudio.com/docs/editor/glob-patterns)",
            "order": 2000
          },
          "axonivy.project.maximumNumber": {
            "type": "integer",
            "default": 50,
            "markdownDescription": "Maximum number of Axon Ivy projects that will be detected.",
            "order": 2100
          },
          "axonivy.process.animation.animate": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "Specify whether processes should be animated during preview."
          },
          "axonivy.process.animation.speed": {
            "type": "integer",
            "default": 50,
            "minimum": 0,
            "maximum": 100,
            "markdownDescription": "Specify process animation speed."
          },
          "axonivy.process.animation.mode": {
            "type": "string",
            "default": "all",
            "enum": [
              "all",
              "currentProcess",
              "openProcesses",
              "noDialogProcesses",
              "noEmbeddedProcesses"
            ],
            "markdownDescription": "Specify process animation mode."
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "ivy-process",
        "label": "Axon Ivy Process Debugger",
        "languages": [
          "ivy-process"
        ],
        "configurationAttributes": {
          "attach": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "properties": {
              "host": {
                "type": "string",
                "description": "Host name of the Axon Ivy Engine DAP server. Defaults to the configured engine host."
              },
              "port": {
                "type": "number",
                "description": "Port of the Axon Ivy Engine DAP server. Defaults to the configured debug port.",
                "minimum": 1,
                "maximum": 65535
              },
              "workspaceFolder": {
                "type": "string",
                "description": "Absolute path of the workspace folder to expose to the Axon Ivy debug adapter. Defaults to the selected workspace folder."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ivy-process",
            "request": "attach",
            "name": "Attach to Axon Ivy Engine"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Axon Ivy: Attach to Engine",
            "description": "Attach the Axon Ivy process debugger to a running engine DAP server.",
            "body": {
              "type": "ivy-process",
              "request": "attach",
              "name": "Attach to Axon Ivy Engine"
            }
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "new_axon_ivy_project",
        "displayName": "New Axon Ivy project",
        "modelDescription": "Scaffolds and registers a new Axon Ivy project. MUST be called for every request to create, add, scaffold, initialize, or generate an Axon Ivy project. Do NOT attempt to create the project by writing files, copying an existing project, or running shell/maven commands — only this tool produces a valid, registered project.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Project name"
            },
            "path": {
              "type": "string",
              "description": "Absolute path to the parent directory where the new project folder should be created."
            },
            "groupId": {
              "type": "string",
              "description": "Dot-separated namespace"
            },
            "projectId": {
              "type": "string",
              "description": "Dot-separated namespace"
            }
          },
          "required": [
            "name",
            "path",
            "groupId",
            "projectId"
          ]
        },
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "newAxonIvyProject"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "ivy-browser-container",
          "title": "Browser",
          "icon": "$(globe)",
          "when": "ivy:hasIvyProjects"
        }
      ]
    },
    "views": {
      "ivy-browser-container": [
        {
          "type": "webview",
          "id": "ivyBrowserView",
          "name": "Browser",
          "when": "ivy:hasIvyProjects",
          "icon": "$(globe)"
        }
      ],
      "explorer": [
        {
          "id": "ivyProjects",
          "name": "Axon Ivy Projects",
          "icon": "./assets/ivy-logo.svg"
        }
      ]
    },
    "submenus": [
      {
        "id": "workflow.editor.title",
        "label": "Diagram"
      },
      {
        "id": "ivyProjects.new",
        "label": "New"
      },
      {
        "id": "explorer.new",
        "label": "Axon Ivy New..."
      },
      {
        "id": "explorer.run",
        "label": "Axon Ivy Run..."
      }
    ],
    "menus": {
      "editor/title": [
        {
          "submenu": "workflow.editor.title",
          "group": "bookmarks"
        },
        {
          "command": "ivyProjects.addDependency",
          "when": "resourceFilename == pom.xml",
          "group": "navigation"
        },
        {
          "command": "ivyBrowserView.openPreview",
          "when": "ivy:dialogPreviewSupported",
          "group": "navigation"
        }
      ],
      "workflow.editor.title": [
        {
          "command": "ivy.debug.attachProcess",
          "group": "navigation",
          "when": "activeCustomEditorId == 'ivy.glspDiagram'"
        },
        {
          "command": "workflow.fit",
          "group": "navigation",
          "when": "activeCustomEditorId == 'ivy.glspDiagram'"
        },
        {
          "command": "workflow.center",
          "group": "navigation",
          "when": "activeCustomEditorId == 'ivy.glspDiagram'"
        },
        {
          "command": "workflow.layout",
          "group": "navigation",
          "when": "activeCustomEditorId == 'ivy.glspDiagram'"
        },
        {
          "command": "workflow.exportAsSVG",
          "when": "activeCustomEditorId == 'ivy.glspDiagram'"
        }
      ],
      "view/title": [
        {
          "command": "ivyProjects.refreshEntry",
          "when": "view == ivyProjects",
          "group": "navigation@3"
        },
        {
          "command": "engine.deployProjects",
          "when": "view == ivyProjects || view == workbench.explorer.fileView"
        }
      ],
      "explorer/context": [
        {
          "submenu": "explorer.new",
          "group": "1@1"
        },
        {
          "submenu": "explorer.run",
          "group": "1@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ivyProjects.deployProject",
          "when": "view == ivyProjects && viewItem == ivyProject",
          "group": "inline"
        },
        {
          "submenu": "ivyProjects.new",
          "when": "view == ivyProjects",
          "group": "ivyProjects@1"
        }
      ],
      "ivyProjects.new": [
        {
          "command": "ivyProjects.addBusinessProcess",
          "group": "1_new@1"
        },
        {
          "command": "ivyProjects.addCallableSubProcess",
          "group": "1_new@2"
        },
        {
          "command": "ivyProjects.addWebServiceProcess",
          "group": "1_new@2"
        },
        {
          "command": "ivyProjects.addNewHtmlDialog",
          "group": "2_new@1"
        },
        {
          "command": "ivyProjects.addNewFormDialog",
          "group": "2_new@2"
        },
        {
          "command": "ivyProjects.addNewOfflineDialog",
          "group": "2_new@3"
        },
        {
          "command": "ivyProjects.addNewDataClass",
          "group": "3_new@1"
        },
        {
          "command": "ivyProjects.addNewEntityClass",
          "group": "3_new@2"
        },
        {
          "command": "ivyProjects.addNewCaseMap",
          "group": "4_new@1"
        }
      ],
      "explorer.new": [
        {
          "command": "ivyProjects.addBusinessProcess",
          "group": "1_new@1",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addCallableSubProcess",
          "group": "1_new@2",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addWebServiceProcess",
          "group": "1_new@2",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewHtmlDialog",
          "group": "2_new@1",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewFormDialog",
          "group": "2_new@2",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewOfflineDialog",
          "group": "2_new@3",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewDataClass",
          "group": "3_new@1",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewEntityClass",
          "group": "3_new@2",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewCaseMap",
          "group": "4_new@1",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addNewProject",
          "group": "5_new@1"
        }
      ],
      "explorer.run": [
        {
          "command": "ivy.debug.attachProcess",
          "group": "run@1",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.deployProject",
          "group": "run@2",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.stopBpmEngine",
          "group": "run@4",
          "when": "ivy:hasIvyProjects"
        },
        {
          "command": "ivyProjects.addDependency",
          "group": "run@5",
          "when": "ivy:hasIvyProjects"
        }
      ]
    },
    "keybindings": [
      {
        "key": "alt+f",
        "mac": "alt+f",
        "command": "workflow.fit",
        "when": "activeCustomEditorId == 'ivy.glspDiagram'"
      },
      {
        "key": "alt+c",
        "mac": "alt+c",
        "command": "workflow.center",
        "when": "activeCustomEditorId == 'ivy.glspDiagram'"
      },
      {
        "key": "ctrl+a",
        "mac": "ctrl+a",
        "command": "workflow.selectAll",
        "when": "activeCustomEditorId == 'ivy.glspDiagram'"
      },
      {
        "key": "alt+l",
        "mac": "alt+l",
        "command": "workflow.layout",
        "when": "activeCustomEditorId == 'ivy.glspDiagram'"
      }
    ],
    "languages": [
      {
        "id": "ivy-process",
        "icon": {
          "light": "./assets/light/diagram-project-solid.svg",
          "dark": "./assets/dark/diagram-project-solid.svg"
        },
        "extensions": [
          ".p.json"
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "ivyProjects",
        "contents": "You have not yet opened a folder.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      },
      {
        "view": "ivyProjects",
        "contents": "There are no Axon Ivy projects. Create one by clicking the button below.\n[Create Axon Ivy Project](command:ivyProjects.addNewProject)",
        "when": "workbenchState != empty && !ivy:hasIvyProjects && ivy:isStarted"
      }
    ]
  }
}
