{
  "private": true,
  "name": "@axonivy/vscode-designer-playwright",
  "scripts": {
    "type": "tsc --noEmit",
    "download:vscode": "node --experimental-strip-types tests/utils/download-vscode.ts",
    "test:ui": "playwright test --project=integration-parallel && playwright test --project=integration-serial",
    "test:ui:performance": "playwright test --project=performance"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@vscode/test-electron": "2.5.2"
  },
  "version": "14.0.0"
}
