{
  "private": true,
  "name": "@axonivy/vscode-designer-playwright",
  "scripts": {
    "type": "tsc --noEmit",
    "download:vscode": "node --experimental-strip-types tests/utils/download-vscode.ts",
    "test:ui": "playwright test --project=integration-parallel;s1=?;playwright test --project=integration-serial;s2=?;[ $s1 -eq 0 ] && [ $s2 -eq 0 ]",
    "test:ui:performance": "playwright test --project=performance"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@vscode/test-electron": "2.5.2"
  },
  "version": "14.0.0"
}
