{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "${env:CONTAINER_WORKSPACE}"
      ],
      "outFiles": ["${workspaceFolder}/extension/dist/extension.js"],
      "sourceMaps": true,
      "preLaunchTask": "watch extension"
    }
  ]
}
