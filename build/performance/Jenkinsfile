pipeline {
  agent {
    // label 'windows-vscode'
    label 'windows-build41'
  }

  tools {
    jdk 'temurin-jdk-25.0.2.10'
    maven '3.9'
  }

  options {
    buildDiscarder(logRotator(numToKeepStr: '60', artifactNumToKeepStr: '2'))
    disableConcurrentBuilds()
  }

  triggers {
    cron '@midnight'
  }

  environment {
    CI = 'true'
    RUN_STABLE_VERSION = 'true'
  }

  stages {

    stage('Build') {
      steps {
        nodejs(nodeJSInstallationName: '24.15.0') {
          bat 'pnpm install'
          bat 'pnpm run update:axonivy:next'
          bat 'pnpm run build:production'
          bat 'pnpm run test:playwright:download:vscode'
        }
        script {

          def statusCleanup = bat(
            label: 'Cleanup portal directory',
            returnStatus: true,
            script: '''
            @echo off
            if exist "playwright\\tests\\workspaces\\portalPerformance\\portal" (
              echo Portal directory exists, cleaning up...
              rmdir /s /q "playwright\\tests\\workspaces\\portalPerformance\\portal"
            ) else (
              echo Portal directory does not exist, skipping cleanup.
            )
            '''
          )
            echo "Cleanup exited with status ${statusCleanup}"

          // TODO: Reset to default branch instead of jakarta later
          bat 'git clone -b jakarta https://github.com/axonivy-market/portal.git playwright/tests/workspaces/portalPerformance/portal || exit /b 0'
          bat 'git -C playwright/tests/workspaces/portalPerformance/portal pull'
          // TODO: Remove this workaround as soon as vscode properly handles the build and deploy order
          maven cmd: 'clean verify ' +
                    '-f playwright/tests/workspaces/portalPerformance/portal/pom.xml'
        }
      }
    }

    stage('Playwright Performance Tests') {
      steps {
        nodejs(nodeJSInstallationName: '24.15.0') {
          catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
            bat 'pnpm run test:playwright:performance'
          }

          echo 'Listing playwright directory contents:'
          bat 'dir playwright'

          echo 'Listing playwright test-user-data-dir directory contents:'
          bat 'dir playwright\\test-user-data-dir'

          echo 'Listing full test-user-data-dir directory contents:'
          bat 'dir /s playwright\\test-user-data-dir\\User\\globalStorage\\axonivy.vscode-designer-14\\engines\\'

          archiveArtifacts artifacts: 'playwright/test-results/**', allowEmptyArchive: true
          archiveArtifacts artifacts: 'playwright/test-user-data-dir/User/globalStorage/axonivy.vscode-designer*/engines/*Slim*All*/logs/**', allowEmptyArchive: true
          withChecks('Performance Tests') {
            junit testDataPublishers: [[$class: 'StabilityTestDataPublisher']], testResults: 'node_modules/**/report.xml'
          }
        }
      }
    }
  }

  post {
    success {
      catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
        cleanWs()
      }
    }
    always {
      catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
        dir('playwright/tests/workspaces/portalPerformance/portal') {
          deleteDir()
        }
      }
    }
  }
}
